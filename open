        function Box:Remove()
            if self.Quad then
                self.Quad.Visible = false
                self.Quad:Remove()
                self.Quad = nil
            end
            if self.Billboard then
                self.Billboard:Destroy()
                self.Billboard = nil
            end
            WeaponESP.Objects[self.Object] = nil
        end
        
        function Box:Update()
            if not self.PrimaryPart or not self.PrimaryPart.Parent then self:Remove() return end
            if not Debris or not Debris:IsAncestorOf(self.Object) then self:Remove() return end
            
            local visible = WeaponESP.Enabled and WeaponESP.Boxes and self.Quad
            if not visible then
                if self.Quad then self.Quad.Visible = false end
                if self.Billboard then self.Billboard.Enabled = false end
                return
            else
                if self.Quad then self.Quad.Visible = true end
                if self.Billboard then self.Billboard.Enabled = true end
            end
            
            local objPos = self.PrimaryPart:IsA("BasePart") and self.PrimaryPart.Position or self.PrimaryPart:GetPivot().Position
            local d = getDistance(objPos)
            local s = math.clamp(30 / math.max(d, 5), 0.3, 1.5)
            
            self.Billboard.Size = UDim2.new(0, 200 * s, 0, 50 * s)
            self.NameLabel.TextSize = 14 * s
            self.SkinLabel.TextSize = 12 * s
            
            local cf = self.PrimaryPart:IsA("BasePart") and self.PrimaryPart.CFrame or self.PrimaryPart:GetPivot()
            local sz = self.Size
            local hx, hy, hz = sz.X / 2, sz.Y / 2, sz.Z / 2
            local corners = {
                cf * Vector3.new( hx,  hy,  hz), cf * Vector3.new( hx,  hy, -hz),
                cf * Vector3.new( hx, -hy,  hz), cf * Vector3.new( hx, -hy, -hz),
                cf * Vector3.new(-hx,  hy,  hz), cf * Vector3.new(-hx,  hy, -hz),
                cf * Vector3.new(-hx, -hy,  hz), cf * Vector3.new(-hx, -hy, -hz)
            }
            
            local proj, allOn = {}, true
            for i, p in ipairs(corners) do
                local v = cam:WorldToViewportPoint(p)
                if v.Z <= 0 then allOn = false end
                proj[i] = Vector2.new(v.X, v.Y)
            end
            
            if not allOn then
                self.Quad.Visible = false
                return
            else
                self.Quad.Visible = true
            end
            
            local minX, maxX, minY, maxY = math.huge, -math.huge, math.huge, -math.huge
            for _, p in ipairs(proj) do
                if p.X < minX then minX = p.X end
                if p.X > maxX then maxX = p.X end
                if p.Y < minY then minY = p.Y end
                if p.Y > maxY then maxY = p.Y end
            end
            
            self.Quad.PointA = Vector2.new(maxX, minY)
            self.Quad.PointB = Vector2.new(minX, minY)
            self.Quad.PointC = Vector2.new(minX, maxY)
            self.Quad.PointD = Vector2.new(maxX, maxY)
            self.Quad.Color = self.Color
            self.Quad.Thickness = self.Thickness
        end
        
        local function addWeapon(obj)
            if WeaponESP.Objects[obj] then return end
            local info = getInfo(obj)
            if not info or not info.weapon then return end
            if obj:IsA("BasePart") then
                local p = obj.Parent
                if p and p:IsA("Model") and getInfo(p) then return end
            end
            local primary = obj:IsA("BasePart") and obj or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")))
            if not primary then return end
            Box.new(obj, { PrimaryPart = primary, Color = WeaponESP.Color, Thickness = WeaponESP.Thickness, info = info })
        end
        
        local function scanAllWeapons()
            if not Debris then return end
            for _, o in ipairs(Debris:GetChildren()) do
                addWeapon(o)
                if o:IsA("Folder") or o:IsA("Model") then
                    for _, c in ipairs(o:GetChildren()) do
                        addWeapon(c)
                    end
                end
            end
        end
        
