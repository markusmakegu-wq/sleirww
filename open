        local function CreateSimpleCham(part, color, trans)
            local cham = Instance.new("BoxHandleAdornment")
            cham.Size = part.Size + Vector3.new(0.05,0.05,0.05)
            cham.Adornee = part
            cham.AlwaysOnTop = true
            cham.ZIndex = 10
            cham.Color3 = color
            cham.Transparency = trans or 0
            cham.Name = "Chams"
            cham.Parent = part
            return cham
        end
        
        local function UpdateChams()
            -- Удаляем все старые чамсы
            for _, plr in Players:GetPlayers() do
                local char = plr.Character
                if char then
                    for _, part in char:GetChildren() do
                        if part:IsA("BasePart") then
                            RemoveAdorns(part)
                        end
                    end
                end
            end
            
            if not _G.Config.ChamsEnabled then return end
            
            -- Применяем чамсы к врагам
            for _, plr in Players:GetPlayers() do
                if plr ~= LocalPlayer and plr.Character and IsEnemy(plr) then
                    for _, part in plr.Character:GetChildren() do
                        if part:IsA("BasePart") and part.Transparency < 1 then
                            CreateSimpleCham(part, _G.Config.ChamsColor, _G.Config.ChamsTransparency)
                        end
                    end
                end
            end
            
            -- Если включен Third Person, добавляем чамсы на себя
            if _G.Config.MiscThirdPerson and LocalPlayer.Character then
                for _, part in LocalPlayer.Character:GetChildren() do
                    if part:IsA("BasePart") and part.Transparency < 1 then
                        CreateSimpleCham(part, _G.Config.ChamsColor, _G.Config.ChamsTransparency)
                    end
                end
            end
        end
        
