        end
        
        local function IsVisibleSilent(part)
            local char = LocalPlayer.Character
            if not char then return false end
            local params = RaycastParams.new()
            params.FilterType = Enum.RaycastFilterType.Exclude
            params.FilterDescendantsInstances = {char, Camera}
            local result = Workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, params)
            return result == nil or result.Instance:IsDescendantOf(part.Parent)
        end
        
        local function getClosestPlayerSilent()
            local closest = nil
            local shortestDistance = _G.Config.Fov
            local mousePos = UserInputService:GetMouseLocation()
                
            local players = Players:GetPlayers()
            for i = 1, #players do
                local p = players[i]
                if p ~= LocalPlayer and p.Character and teamCheckSilent(p) then
                    local targetPart = p.Character:FindFirstChild(_G.Config.AimPart)
                    if targetPart then
                        local humanoid = p.Character:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid.Health > 0 then
                            if _G.Config.AimbotUseVisibleCheck and not IsVisibleSilent(targetPart) then continue end
                            
                            local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                            if onScreen then
                                local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                                if distance < shortestDistance then
                                    shortestDistance = distance
                                    closest = p.Character
                                end
                            end
                        end
                    end
                end
            end
            return closest
        end
        
        -- Функция для выбора части тела с учётом MissChance
        local function getTargetPartWithMiss(targetChar)
            if not targetChar then return nil end
            -- Если MissChance сработал, целимся в MissPart, иначе в AimPart
            if math.random(1, 100) <= _G.Config.MissChance then
                return targetChar:FindFirstChild(_G.Config.MissPart) or targetChar:FindFirstChild(_G.Config.AimPart) or targetChar:FindFirstChild("Head")
            else
                return targetChar:FindFirstChild(_G.Config.AimPart) or targetChar:FindFirstChild("Head")
            end
        end
        
        local function SetupSilentAim()
            local success, err = pcall(function()
                local BulletModule = ReplicatedStorage:WaitForChild("Components"):WaitForChild("Weapon"):WaitForChild("Classes"):WaitForChild("Bullet")
                local Bullet = require(BulletModule)
                local realMath = math
                
                getfenv(Bullet._performRaycast).math = setmetatable({}, {
                    __index = function(_, index)
                        if index == "min" then
                            -- Проверяем, нажата ли кнопка мыши (выстрел)
                            if not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                                return realMath.min
                            end
                            local target = getClosestPlayerSilent()
                            if target and _G.Config.SilentAim then
                                if realMath.random(1, 100) <= _G.Config.HitChance then
                                    local part = getTargetPartWithMiss(target)
                                    if part then
                                        debug.setstack(2, 5, Ray.new(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit))
                                        return function() return 0 end
                                    end
                                end
                            end
                        end
                        return realMath[index]
                    end
                })
            end)
            
            if not success then
                warn("Silent Aim setup failed:", err)
            end
        end
        
