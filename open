            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.BackgroundTransparency = 1
            Label.Parent = SldFrame
            
            local Bar = Instance.new("Frame")
            Bar.Size = UDim2.new(1, 0, 0, 5)
            Bar.Position = UDim2.new(0, 0, 0, 22)
            Bar.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            Bar.BorderSizePixel = 1
            Bar.Parent = SldFrame
            
            local Fill = Instance.new("Frame")
            Fill.Size = UDim2.new((_G.Config[config_key] - min) / (max - min), 0, 1, 0)
            Fill.BackgroundColor3 = Color3.fromRGB(150, 200, 60)
            Fill.BorderSizePixel = 0
            Fill.Parent = Bar
            
            if not UI_Elements[config_key] then
                UI_Elements[config_key] = {}
            end
            table.insert(UI_Elements[config_key], {
                Type = "Slider",
                Name = name,
                Label = Label,
                Fill = Fill,
                Max = max,
                Min = min
            })
            
            local function UpdateSlider(input)
                local per = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
                local val = math.floor(min + (max - min) * per)
                Fill.Size = UDim2.new(per, 0, 1, 0)
                Label.Text = name .. ": " .. val
                _G.Config[config_key] = val
                if callback then callback(val) end
            end
            
            local draggingBar = false
            Bar.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingBar = true
                    UpdateSlider(i)
                end
            end)
            UIS.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingBar = false
                end
            end)
            UIS.InputChanged:Connect(function(i)
                if draggingBar and i.UserInputType == Enum.UserInputType.MouseMovement then
                    UpdateSlider(i)
                end
            end)
            
            return SldFrame
        end
        
        local function CreateDropdown(parent, name, options, config_key, callback)
            local Btn = Instance.new("TextButton")
            Btn.Size = UDim2.new(1, 0, 0, 20)
            Btn.BackgroundTransparency = 1
            Btn.Font = Enum.Font.Code
            Btn.TextSize = 13
            Btn.TextXAlignment = Enum.TextXAlignment.Left
            Btn.TextColor3 = Color3.new(1, 1, 1)
            Btn.Parent = parent
            
            local function UpdateText()
                if typeof(_G.Config[config_key]) == "EnumItem" then
                    local str = tostring(_G.Config[config_key]):gsub("Enum.KeyCode.",""):gsub("Enum.UserInputType.","")
                    Btn.Text = name .. ": " .. str
                else
                    Btn.Text = name .. ": " .. tostring(_G.Config[config_key])
                end
            end
            UpdateText()
            
            if not UI_Elements[config_key] then
                UI_Elements[config_key] = {}
            end
            table.insert(UI_Elements[config_key], {
                Type = "Dropdown",
                Name = name,
                Btn = Btn
            })
            
            Btn.MouseButton1Click:Connect(function()
                if typeof(_G.Config[config_key]) == "EnumItem" then
                    local keys = {Enum.KeyCode.X, Enum.KeyCode.V, Enum.KeyCode.C, Enum.UserInputType.MouseButton2}
                    local idx = 1
                    for i, k in ipairs(keys) do
                        if k == _G.Config[config_key] then
                            idx = i + 1
                            if idx > #keys then idx = 1 end
                            break
                        end
                    end
                    _G.Config[config_key] = keys[idx]
                else
                    local idx = 1
                    for i, opt in ipairs(options) do
                        if opt == _G.Config[config_key] then
                            idx = i + 1
                            if idx > #options then idx = 1 end
                            break
                        end
                    end
                    _G.Config[config_key] = options[idx]
                end
                UpdateText()
                if callback then callback(_G.Config[config_key]) end
            end)
            
            return Btn
        end
        
